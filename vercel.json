{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist/public",
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 60,
      "includeFiles": ["server/**", "shared/**"]
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index?route=:path*"
    },
    {
      "source": "/:path((?!api(?:/|$)).*)",
      "destination": "/index.html"
    }
  ]
}
